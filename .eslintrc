{
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "prefer-const": "error",
    "no-var": "error",

    "eqeqeq": ["error", "always"],
    "no-implicit-globals": "error",
    "no-eval": "error",
    "no-implied-eval": "error",

    "no-console": "off",
    "curly": ["warn", "multi-line"],
    "no-else-return": "warn"
  },
  "ignorePatterns": [
    "dist/",
    "build/",
    "*.min.js",
    "vendor/",
    "node_modules/"
  ]
}
